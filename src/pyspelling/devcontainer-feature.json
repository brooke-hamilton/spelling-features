{
    "name": "pyspelling",
    "id": "pyspelling",
    "version": "1.0.0",
    "description": "Installs pyspelling, a spell checking tool powered by Aspell",
    "documentationURL": "https://github.com/facelessuser/pyspelling",
    "licenseURL": "https://github.com/brooke-hamilton/features/blob/main/LICENSE",
    "options": {
        "version": {
            "type": "string",
            "default": "latest",
            "description": "Version of pyspelling to install (e.g., 'latest', '2.10', '2.9')",
            "proposals": ["latest"]
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
